{
  "version": 2,
  "builds": [
    { "src": "api/submit.js",       "use": "@vercel/node" },
    { "src": "api/get-result.js",   "use": "@vercel/node" },
    { "src": "index.html",          "use": "@vercel/static" },
    { "src": "dashboard.html",      "use": "@vercel/static" },
    { "src": "style.css",           "use": "@vercel/static" },
    { "src": "app.js",              "use": "@vercel/static" },
    { "src": "dashboard.js",        "use": "@vercel/static" },
    { "src": "disc_questions.json", "use": "@vercel/static" },
    { "src": "home-icon.png",        "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/submit",
      "dest": "api/submit.js",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    },
    {
      "src": "/api/get-result",
      "dest": "api/get-result.js",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    },
    { "src": "/style.css",           "dest": "style.css" },
    { "src": "/app.js",              "dest": "app.js" },
    { "src": "/dashboard.js",        "dest": "dashboard.js" },
    { "src": "/disc_questions.json", "dest": "disc_questions.json" },
    { "src": "/home-icon.png",        "dest": "home-icon.png" },
    { "src": "/dashboard",           "dest": "dashboard.html" },
    { "src": "/dashboard.html",      "dest": "dashboard.html" },
    { "src": "/(.*)",                "dest": "index.html" }
  ]
}
